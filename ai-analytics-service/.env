APP_NAME=ai-analysis-service
ENVIRONMENT=local
LOG_LEVEL=INFO
API_PREFIX=/api/v1

HOST=0.0.0.0
PORT=8090

DATABASE_URL=postgresql://incidents:incidents@postgres:5432/incidents

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TRACE_TOPIC=trace-events
KAFKA_CONSUMER_GROUP=ai-analysis-group
KAFKA_CONSUMER_ENABLED=false

REDIS_URL=redis://redis:6379
REDIS_ANALYSIS_CHANNEL=analysis:live

LLM_PROVIDER=opencode
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODELS=deepseek-v4-flash-free,qwen3.6-plus-free,minimax-m3-free,nemotron-3-ultra-free
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=30
